<Window x:Class="Vzlom.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vzlom Algorithmic"
        Width="1200" Height="800"
        Background="{StaticResource BgDarkBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Consolas"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="24"/>
        </Grid.RowDefinitions>

        <!-- Title Bar Custom -->
        <Border Grid.Row="0" Background="{StaticResource BgMediumBrush}" 
                MouseLeftButtonDown="OnTitleBarDrag">
            <Grid Margin="4,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="VZLOM ALGORITHMIC" 
                           Foreground="{StaticResource AccentBrush}" 
                           FontSize="12" VerticalAlignment="Center" Margin="8,0"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="BtnPin" Content="📌" Click="OnPin" Width="24" Height="24" Padding="0"/>
                    <Button Content="─" Click="OnMinimize" Width="24" Height="24" Padding="0"/>
                    <Button x:Name="BtnMax" Content="□" Click="OnMaximize" Width="24" Height="24" Padding="0"/>
                    <Button Content="✕" Click="OnClose" Width="24" Height="24" Padding="0" 
                            Background="{StaticResource AccentRedBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1" Margin="4,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{StaticResource BgMediumBrush}" CornerRadius="4">
                <StackPanel VerticalAlignment="Center" Margin="0,8">
                    <Button x:Name="BtnEditor" Content="📝" Click="OnSwitchEditor" 
                            Width="36" Height="36" FontSize="18" Padding="0" Margin="0,0,0,8"/>
                    <Button x:Name="BtnHermes" Content="🤖" Click="OnSwitchHermes" 
                            Width="36" Height="36" FontSize="18" Padding="0"/>
                </StackPanel>
            </Border>

            <!-- Page container -->
            <ContentControl Grid.Column="1" x:Name="PageContainer" Margin="8,0,0,0"/>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="{StaticResource BgMediumBrush}" CornerRadius="0,0,4,4">
            <Grid Margin="6,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Grid.Column="0" 
                           Text="Prêt" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                <TextBlock x:Name="BypassIndicator" Grid.Column="1" 
                           Text="" Foreground="{StaticResource AccentGreenBrush}" FontSize="11"/>
            </Grid>
        </Border>
    </Grid>
</Window>
