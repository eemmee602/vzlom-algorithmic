<Window x:Class="Vzlom.Controls.PermissionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Autorisation requise"
        Width="480" Height="280"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgDarkBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Consolas"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        Topmost="True">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Description}" 
                   TextWrapping="Wrap" FontSize="14" 
                   Foreground="{StaticResource TextPrimaryBrush}" 
                   Margin="0,0,0,12"/>

        <StackPanel Grid.Row="2" Margin="0,12,0,0">
            <Button Content="✅ Autoriser une fois" Tag="AllowOnce" 
                    Click="OnChoice" Margin="0,0,0,4" Height="32"/>
            <Button Content="⏳ Autoriser pour la session" Tag="AllowSession" 
                    Click="OnChoice" Margin="0,0,0,4" Height="32"/>
            <Button Content="🔁 Toujours autoriser" Tag="AllowAlways" 
                    Click="OnChoice" Margin="0,0,0,4" Height="32"/>
            <Button Content="⛔ Refuser" Tag="Deny" 
                    Click="OnChoice" Height="32"
                    Background="{StaticResource AccentRedBrush}"/>
        </StackPanel>
    </Grid>
</Window>
