<Window x:Class="Vzlom.Controls.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⚙ Paramètres Vzlom"
        Width="500" Height="450"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgDarkBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Consolas"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        Topmost="True">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Background="{StaticResource BgMediumBrush}" 
                     BorderThickness="0" Height="28">
            <TabItem Header="🔑 API Keys" Background="{StaticResource BgDarkBrush}" Foreground="{StaticResource TextPrimaryBrush}"/>
            <TabItem Header="🔌 SSH" Background="{StaticResource BgDarkBrush}" Foreground="{StaticResource TextPrimaryBrush}"/>
            <TabItem Header="🤖 Modèle" Background="{StaticResource BgDarkBrush}" Foreground="{StaticResource TextPrimaryBrush}"/>
        </TabControl>

        <ScrollViewer Grid.Row="1" Margin="0,8">
            <StackPanel x:Name="SettingsPanel" Margin="0,0,4,0">
                <TextBlock Text="Ajoute tes clés API (OpenRouter, OpenAI, Anthropic...)" 
                           Foreground="{StaticResource TextSecondaryBrush}" 
                           FontSize="12" Margin="0,0,0,8"/>
                <TextBox x:Name="NewKeyBox" FontSize="12" Height="28" 
                         Text="sk-or-v1-..." Margin="0,0,0,4"/>
                <Button Content="➕ Ajouter la clé" Click="OnAddKey" Height="28" Margin="0,0,0,8"/>

                <TextBlock Text="Clés enregistrées :" Foreground="{StaticResource AccentBrush}" 
                           FontSize="12" Margin="0,8,0,4"/>
                <ListBox x:Name="KeyList" Background="{StaticResource BgDarkBrush}" 
                         BorderBrush="{StaticResource BorderBrush}" Height="100"
                         DisplayMemberPath="Display"/>

                <Button Content="🗑 Supprimer la sélection" Click="OnRemoveKey" 
                        Height="26" Margin="0,4,0,8"
                        Background="{StaticResource AccentRedBrush}"/>

                <Separator Margin="0,8" Opacity="0.3"/>

                <!-- SSH -->
                <TextBlock Text="🔌 Connexion SSH (Advin)" 
                           Foreground="{StaticResource AccentBrush}" 
                           FontSize="14" Margin="0,8,0,4"/>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="26"/>
                        <RowDefinition Height="26"/>
                        <RowDefinition Height="26"/>
                        <RowDefinition Height="26"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Hôte : " VerticalAlignment="Center"/>
                    <TextBox x:Name="SshHost" Grid.Row="0" Grid.Column="1" Text="" FontSize="12"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Port : " VerticalAlignment="Center"/>
                    <TextBox x:Name="SshPort" Grid.Row="1" Grid.Column="1" Text="22" FontSize="12"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="User : " VerticalAlignment="Center"/>
                    <TextBox x:Name="SshUser" Grid.Row="2" Grid.Column="1" Text="" FontSize="12"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Password : " VerticalAlignment="Center"/>
                    <TextBox x:Name="SshPass" Grid.Row="3" Grid.Column="1" Text="" FontSize="12"/>
                </Grid>
                <Button Content="💾 Sauver SSH + Connecter" Click="OnSaveSsh" 
                        Height="28" Margin="0,4,0,8"/>

                <Separator Margin="0,8" Opacity="0.3"/>

                <!-- Modèle -->
                <TextBlock Text="🤖 Modèle IA" Foreground="{StaticResource AccentBrush}" 
                           FontSize="14" Margin="0,8,0,4"/>
                <TextBox x:Name="ModelBox" FontSize="12" Height="28" 
                         Text="openai/gpt-4o" Margin="0,0,0,4"/>
                <TextBlock Text="Fallbacks (un par ligne) :" 
                           Foreground="{StaticResource TextSecondaryBrush}" 
                           FontSize="11" Margin="0,4,0,2"/>
                <TextBox x:Name="FallbackBox" FontSize="11" Height="60" 
                         TextWrapping="Wrap" AcceptsReturn="True"
                         Text="anthropic/claude-sonnet-4-20250514&#x0a;google/gemini-2.5-pro&#x0a;deepseek/deepseek-chat"/>
                <Button Content="💾 Sauver modèle" Click="OnSaveModel" 
                        Height="28" Margin="0,4,0,0"/>
            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="2" Content="✅ Fermer" Click="OnClose" 
                Height="32" Margin="0,8,0,0"
                Background="{StaticResource AccentGreenBrush}" Foreground="#000"/>
    </Grid>
</Window>
