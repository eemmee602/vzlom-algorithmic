<UserControl x:Class="Vzlom.Faces.EditorFace"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
             Background="{StaticResource BgDarkBrush}">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
            <Button Content="📂 Ouvrir" x:Name="BtnOpen" Click="OnOpen" Margin="0,0,4,0"/>
            <Button Content="💾 Sauver" x:Name="BtnSave" Click="OnSave" Margin="0,0,4,0"/>
            <Button Content="▶ Exécuter" x:Name="BtnRun" Click="OnRun" 
                    Background="{StaticResource AccentGreenBrush}" Foreground="#000" Margin="0,0,4,0"/>
            <Button Content="✖ Tout effacer" x:Name="BtnClear" Click="OnClear"/>
        </StackPanel>

        <!-- Editor -->
        <Border Grid.Row="1" BorderBrush="{StaticResource BorderBrush}" 
                BorderThickness="1" CornerRadius="4">
            <avalonedit:TextEditor x:Name="Editor"
                                   SyntaxHighlighting="C#
                                   FontFamily="Consolas"
                                   FontSize="14"
                                   ShowLineNumbers="True"
                                   Background="{StaticResource BgDarkBrush}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   LineNumbersForeground="{StaticResource TextSecondaryBrush}"/>
        </Border>

        <!-- Info bar -->
        <TextBlock Grid.Row="2" x:Name="InfoBar" 
                   Text="Prêt" Foreground="{StaticResource TextSecondaryBrush}" 
                   FontSize="11" Margin="0,4,0,0"/>
    </Grid>
</UserControl>
